{
  "name": "@kitsuyui/react-use",
  "version": "17.6.0",
  "description": "Kitsuyui fork of react-use, a collection of React Hooks",
  "homepage": "https://github.com/kitsuyui/react-use#readme",
  "bugs": {
    "url": "https://github.com/kitsuyui/react-use/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsuyui/react-use"
  },
  "license": "Unlicense",
  "author": "@kitsuyui",
  "contributors": [
    "@streamich"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typings": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "bun rm -rf dist coverage",
    "format": "biome format --write .",
    "format:package-json": "sort-package-json package.json",
    "lint": "bun run lint:biome && bun run typecheck",
    "lint:biome": "biome lint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=clover --coverage.reporter=text --coverage.reportsDirectory=coverage/unit",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate": "bun pm pack --dry-run >/dev/null"
  },
  "dependencies": {
    "fast-shallow-equal": "^1.0.0",
    "tslib": "^2.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@testing-library/react": "12.1.5",
    "@testing-library/react-hooks": "7.0.2",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.3.0",
    "@types/react": "17.0.0",
    "@types/react-dom": "17.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "jsdom": "^28.1.0",
    "raf-stub": "3.0.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-test-renderer": "17.0.2",
    "sort-package-json": "^3.6.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  },
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public"
  }
}
