{
  "name": "@kitsuyui/react-use",
  "version": "17.6.0",
  "description": "Kitsuyui fork of react-use, a collection of React Hooks",
  "homepage": "https://github.com/kitsuyui/react-use#readme",
  "bugs": {
    "url": "https://github.com/kitsuyui/react-use/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsuyui/react-use"
  },
  "license": "Unlicense",
  "author": "@streamich, @kitsuyui",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typings": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "bun rm -rf dist coverage",
    "format": "biome format --write .",
    "lint": "bun run lint:biome && bun run typecheck",
    "lint:biome": "biome lint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=clover --coverage.reporter=text --coverage.reportsDirectory=coverage/unit",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate": "bun pm pack --dry-run >/dev/null"
  },
  "release": {
    "branches": [
      "main",
      {
        "name": "next",
        "prerelease": "rc"
      }
    ],
    "prepare": [
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/git"
    ],
    "verifyConditions": [
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/git"
    ]
  },
  "dependencies": {
    "@types/js-cookie": "^2.2.6",
    "@xobotyi/scrollbar-width": "^1.9.5",
    "copy-to-clipboard": "^3.3.1",
    "fast-deep-equal": "^3.1.3",
    "fast-shallow-equal": "^1.0.0",
    "js-cookie": "^2.2.1",
    "nano-css": "^5.6.2",
    "react-universal-interface": "^0.6.2",
    "resize-observer-polyfill": "^1.5.1",
    "screenfull": "^5.1.0",
    "set-harmonic-interval": "^1.0.1",
    "throttle-debounce": "^3.0.1",
    "ts-easing": "^0.2.0",
    "tslib": "^2.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/npm": "12.0.2",
    "@shopify/jest-dom-mocks": "2.11.7",
    "@testing-library/react": "12.1.5",
    "@testing-library/react-hooks": "7.0.2",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.3.0",
    "@types/react": "17.0.0",
    "@types/react-dom": "17.0.0",
    "@vitest/coverage-v8": "4.0.18",
    "jsdom": "^28.1.0",
    "keyboardjs": "2.7.0",
    "raf-stub": "3.0.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-frame-component": "5.2.7",
    "react-spring": "9.7.5",
    "react-test-renderer": "17.0.2",
    "rebound": "0.1.0",
    "redux-logger": "3.0.6",
    "redux-thunk": "2.4.2",
    "rxjs": "7.8.2",
    "semantic-release": "24.2.7",
    "sort-package-json": "^3.6.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  },
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public"
  },
  "collective": {
    "type": "opencollective",
    "url": "https://opencollective.com/react-use"
  }
}
